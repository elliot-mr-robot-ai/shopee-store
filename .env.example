# Payload CMS - Shopee Store
# Preencha com as suas credenciais

# Secret para Payload (gere uma string aleatória)
PAYLOAD_SECRET=your-secret-key-here

# URL do servidor (preencha após deploy no Vercel)
NEXT_PUBLIC_SERVER_URL=https://your-domain.vercel.app

# Neon PostgreSQL Connection String
# Pegue em: https://neon.tech → Dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/shopee-store?sslmode=require
